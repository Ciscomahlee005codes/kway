{
  "name": "kway",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run start --prefix server",
    "build": "cd client && npm install && npm run build",
    "start": "node server/server.js"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}